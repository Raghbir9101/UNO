<!-- Hero holo-card fan: a live canvas render of the game's card material -->
<script>
  (function () {
    var canvas = document.getElementById('hero-canvas');
    if (!canvas || !canvas.getContext) return;
    var ctx = canvas.getContext('2d');
    var REDUCED = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // Logical stage: 920 x 400, cards fan up from the bottom edge
    var LW = 920, LH = 400;
    var CARDS = [
      { color: '#ff3b5c', hot: '#ff8fa3', pip: '7'  },
      { color: '#ffd23f', hot: '#ffe37e', pip: '+2' },
      { color: '#2ee88a', hot: '#7df2b8', pip: '3'  },
      { color: '#3d9dff', hot: '#8ec4ff', pip: '9'  },
      { color: null,      hot: '#ffffff', pip: '★'  } // wild
    ];
    var FAN = [-26, -13, 0, 13, 26]; // final rotation per card (degrees)
    var CW = 148, CH = 216, RAD = 16;
    var DEAL_MS = 520, STAGGER = 90, FOIL_MS = 5200;
    var start = performance.now();

    function size() {
      var dpr = Math.min(window.devicePixelRatio || 1, 2);
      var w = Math.min(920, canvas.parentElement.clientWidth * 1.3);
      var h = w * (LH / LW);
      canvas.width = Math.round(w * dpr);
      canvas.height = Math.round(h * dpr);
      canvas.style.height = h + 'px';
    }

    function rr(x, y, w, h, r) {
      ctx.beginPath();
      ctx.moveTo(x + r, y); ctx.arcTo(x + w, y, x + w, y + h, r);
      ctx.arcTo(x + w, y + h, x, y + h, r); ctx.arcTo(x, y + h, x, y, r);
      ctx.arcTo(x, y, x + w, y, r); ctx.closePath();
    }
    function hexA(hex, a) {
      var n = parseInt(hex.slice(1), 16);
      return 'rgba(' + ((n >> 16) & 255) + ',' + ((n >> 8) & 255) + ',' + (n & 255) + ',' + a + ')';
    }
    function easeOut(p) { return 1 - Math.pow(1 - p, 3); }

    function drawCard(card, idx, now) {
      var t = REDUCED ? 1 : Math.min(Math.max((now - start - idx * STAGGER) / DEAL_MS, 0), 1);
      if (t <= 0) return;
      var e = easeOut(t);
      var rot = FAN[idx] * e * Math.PI / 180;
      // Rest high enough that even the tilted outer cards' corners clear the
      // canvas bottom (they swing ~32px below the center card when rotated)
      var lift = 200 * e;

      ctx.save();
      ctx.translate(LW / 2, LH + CH * 0.72 - lift);
      ctx.rotate(rot);
      ctx.translate(-CW / 2, -CH);
      ctx.globalAlpha = 0.35 + 0.65 * e;

      // Obsidian slab
      ctx.save();
      ctx.shadowColor = 'rgba(0,0,0,0.55)'; ctx.shadowBlur = 18; ctx.shadowOffsetY = 6;
      var body = ctx.createLinearGradient(0, 0, 0, CH);
      body.addColorStop(0, '#1a2237'); body.addColorStop(1, '#0a0e1c');
      rr(0, 0, CW, CH, RAD); ctx.fillStyle = body; ctx.fill();
      ctx.restore();

      // Emissive core + foil sheen, clipped to the card
      ctx.save();
      rr(0, 0, CW, CH, RAD); ctx.clip();
      if (card.color) {
        var core = ctx.createRadialGradient(CW / 2, CH * 0.46, 0, CW / 2, CH * 0.46, CH * 0.6);
        core.addColorStop(0, hexA(card.color, 0.34));
        core.addColorStop(1, 'rgba(0,0,0,0)');
        ctx.fillStyle = core; ctx.fillRect(0, 0, CW, CH);
      } else {
        // Wild: four-corner prism glow
        var qs = [['#ff3b5c', 0.22, 0.2], ['#ffd23f', 0.78, 0.2], ['#3d9dff', 0.22, 0.8], ['#2ee88a', 0.78, 0.8]];
        for (var q = 0; q < 4; q++) {
          var qg = ctx.createRadialGradient(CW * qs[q][1], CH * qs[q][2], 0, CW * qs[q][1], CH * qs[q][2], CW * 0.6);
          qg.addColorStop(0, hexA(qs[q][0], 0.3)); qg.addColorStop(1, 'rgba(0,0,0,0)');
          ctx.fillStyle = qg; ctx.fillRect(0, 0, CW, CH);
        }
      }
      // The signature holo-foil sweep. The sweep overshoots far past both
      // edges so the band's diagonal projection is fully off-card when the
      // loop wraps — otherwise the highlight visibly teleports.
      var p = REDUCED ? 0.38 : (((now % FOIL_MS) / FOIL_MS) + idx * 0.13) % 1;
      var bx = (-2.4 + p * 4.9) * CW;
      var sheen = ctx.createLinearGradient(bx, 0, bx + CW * 0.9, CH);
      sheen.addColorStop(0.3, 'rgba(255,255,255,0)');
      sheen.addColorStop(0.5, hexA(card.color || '#e8ebf3', 0.13));
      sheen.addColorStop(0.7, 'rgba(255,255,255,0)');
      ctx.fillStyle = sheen; ctx.fillRect(0, 0, CW, CH);
      ctx.restore();

      // Pip
      ctx.fillStyle = card.hot;
      ctx.font = "700 " + Math.round(CW * 0.45) + "px 'Space Grotesk', 'Inter', sans-serif";
      ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
      ctx.fillText(card.pip, CW / 2, CH / 2);
      ctx.font = "700 " + Math.round(CW * 0.17) + "px 'Space Grotesk', 'Inter', sans-serif";
      ctx.fillText(card.pip, CW * 0.19, CH * 0.14);

      // Emissive border
      if (card.color) {
        rr(0.5, 0.5, CW - 1, CH - 1, RAD);
        ctx.strokeStyle = hexA(card.color, 0.5); ctx.lineWidth = 1.5; ctx.stroke();
      } else {
        var pg = ctx.createLinearGradient(0, 0, CW, CH);
        pg.addColorStop(0, 'rgba(255,59,92,0.7)'); pg.addColorStop(0.33, 'rgba(255,210,63,0.7)');
        pg.addColorStop(0.66, 'rgba(46,232,138,0.7)'); pg.addColorStop(1, 'rgba(61,157,255,0.7)');
        rr(0.5, 0.5, CW - 1, CH - 1, RAD);
        ctx.strokeStyle = pg; ctx.lineWidth = 1.5; ctx.stroke();
      }
      ctx.restore();
    }

    var running = false, rafId = null, lastFrame = 0;
    function frame(now) {
      if (!running) return;
      // ~30fps is plenty for a slow sheen — halves the paint cost
      if (now - lastFrame >= 33) {
        lastFrame = now;
        var scale = canvas.width / LW;
        ctx.setTransform(scale, 0, 0, scale, 0, 0);
        ctx.clearRect(0, 0, LW, LH);
        // Table glow pool under the fan
        var pool = ctx.createRadialGradient(LW / 2, LH, 0, LW / 2, LH, LW * 0.42);
        pool.addColorStop(0, 'rgba(61,157,255,0.10)');
        pool.addColorStop(1, 'rgba(0,0,0,0)');
        ctx.fillStyle = pool; ctx.fillRect(0, 0, LW, LH);
        for (var i = 0; i < CARDS.length; i++) drawCard(CARDS[i], i, now);
      }
      rafId = requestAnimationFrame(frame);
    }
    function startLoop() {
      if (running) return;
      running = true;
      rafId = requestAnimationFrame(frame);
    }
    function stopLoop() {
      running = false;
      if (rafId) cancelAnimationFrame(rafId);
    }

    size();
    window.addEventListener('resize', function () { size(); });

    if (REDUCED) {
      // One static frame — cards in place, sheen frozen
      startLoop();
      setTimeout(stopLoop, 100);
    } else {
      // Animate only while the hero is on screen and the tab is visible
      if ('IntersectionObserver' in window) {
        new IntersectionObserver(function (entries) {
          entries[0].isIntersecting && !document.hidden ? startLoop() : stopLoop();
        }, { threshold: 0.05 }).observe(canvas);
      } else {
        startLoop();
      }
      document.addEventListener('visibilitychange', function () {
        document.hidden ? stopLoop() : startLoop();
      });
    }
  })();
</script>

<!-- 20-player fan: deal the cards out when the section scrolls into view -->
<script>
  (function () {
    var fan = document.getElementById('big-mp-fan');
    if (!fan) return;
    var REDUCED = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (REDUCED || !('IntersectionObserver' in window)) return; // cards stay in their final fanned state
    fan.classList.add('fan-armed'); // collapse the fan only once we know we can deal it back out
    var io = new IntersectionObserver(function (entries) {
      if (entries[0].isIntersecting) {
        fan.classList.remove('fan-armed');
        io.disconnect();
      }
    }, { threshold: 0.35 });
    io.observe(fan);
  })();
</script>

<!-- Counter animation script -->
<script>
  (function() {
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          var el = entry.target;
          var target = parseInt(el.getAttribute('data-count'), 10);
          if (!target || el.dataset.animated) return;
          el.dataset.animated = '1';
          var duration = 1500;
          var start = performance.now();
          function tick(now) {
            var progress = Math.min((now - start) / duration, 1);
            var eased = 1 - Math.pow(1 - progress, 3);
            el.textContent = Math.round(eased * target).toLocaleString() + (target >= 100 ? '+' : '');
            if (progress < 1) requestAnimationFrame(tick);
          }
          requestAnimationFrame(tick);
          observer.unobserve(el);
        }
      });
    }, { threshold: 0.3 });
    document.querySelectorAll('.proof-number[data-count]').forEach(function(el) {
      observer.observe(el);
    });
  })();
</script>

