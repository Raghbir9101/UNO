<%- include('partials/head') %>
<%- include('partials/nav') %>
<main id="main-content" class="content-page">
  <div class="container">
    <nav class="breadcrumbs" aria-label="Breadcrumb"><a href="/">Home</a><span class="sep">›</span><span>Contact</span></nav>
    <h1>Contact Us</h1>
    <p class="page-subtitle">Have a question, found a bug, or want to say hello? We'd love to hear from you.</p>

    <h2>Get in Touch</h2>
    <p>The best way to reach us is by email:</p>
    <p><strong>Email:</strong> <a href="mailto:<%= supportEmail %>"><%= supportEmail %></a></p>

    <h2 id="report-bug">Report a Bug</h2>
    <p>Found a bug? Tell us what happened and we'll fix it. The more detail the better — what you expected, your device and browser, how many players were in the room, and how to reproduce it.</p>
    <form id="bugReportForm" style="display:grid; gap:14px; max-width:560px; margin:8px 0 16px;">
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:14px;">
        <label style="display:grid; gap:6px; font-size:0.85rem;">Name (optional)
          <input type="text" name="name" maxlength="60" autocomplete="name"
                 style="padding:10px 12px; border-radius:8px; border:1px solid rgba(255,255,255,0.15); background:rgba(255,255,255,0.05); color:inherit; font:inherit;">
        </label>
        <label style="display:grid; gap:6px; font-size:0.85rem;">Email (optional — for updates)
          <input type="email" name="email" maxlength="120" autocomplete="email"
                 style="padding:10px 12px; border-radius:8px; border:1px solid rgba(255,255,255,0.15); background:rgba(255,255,255,0.05); color:inherit; font:inherit;">
        </label>
      </div>
      <label style="display:grid; gap:6px; font-size:0.85rem;">What went wrong? <span aria-hidden="true" style="color:#e34948;">*</span>
        <textarea name="message" required minlength="10" maxlength="2000" rows="5"
                  placeholder="e.g. On my iPhone (Safari), the Wild Draw 8 card froze the game in a 6-player room when…"
                  style="padding:10px 12px; border-radius:8px; border:1px solid rgba(255,255,255,0.15); background:rgba(255,255,255,0.05); color:inherit; font:inherit; resize:vertical;"></textarea>
      </label>
      <!-- Honeypot: hidden from humans, bots fill it and get silently dropped -->
      <input type="text" name="website" tabindex="-1" autocomplete="off" aria-hidden="true"
             style="position:absolute; left:-9999px; width:1px; height:1px; opacity:0;">
      <div style="display:flex; align-items:center; gap:16px;">
        <button type="submit" class="btn btn-hero" id="bugSubmitBtn">Send Bug Report</button>
        <span id="bugFormStatus" role="status" style="font-size:0.9rem;"></span>
      </div>
    </form>

    <h2>Feature Requests</h2>
    <p>We're always looking for ways to improve! If you have an idea for a new feature, send us an email and we'll consider it for our roadmap.</p>

    <h2>Business Inquiries</h2>
    <p>For partnerships, sponsorships, or business inquiries, please email us with the subject line "Business Inquiry."</p>

    <% if (coffeeUrl || upiId) { %>
    <div class="cta-banner" id="support">
      <h3>☕ Enjoying the Game? Buy Me a Coffee</h3>
      <p>Play UNO Free is built and run by one person, with no ads and no paywalls. If the game has given you a fun evening, a coffee keeps the servers running.</p>
      <% if (upiId) { %>
      <div style="display:inline-block; background:#ffffff; padding:14px; border-radius:12px; margin:12px 0;">
        <a href="upi://pay?pa=<%= encodeURIComponent(upiId) %>&pn=<%= encodeURIComponent(upiName) %>&cu=INR" aria-label="Pay with any UPI app">
          <img src="/upi-qr.svg" alt="UPI payment QR code" width="180" height="180" style="display:block;">
        </a>
      </div>
      <p style="margin:4px 0 12px;">
        Scan with <strong>GPay</strong>, PhonePe, Paytm, or any UPI app — or tap the QR on your phone.<br>
        <span style="font-family:monospace; font-size:0.9rem; opacity:0.85;">UPI ID: <%= upiId %></span>
      </p>
      <% } %>
      <% if (coffeeUrl) { %>
      <a href="<%= coffeeUrl %>" target="_blank" rel="noopener" class="btn btn-hero">Buy Me a Coffee</a>
      <% } %>
    </div>
    <% } %>
  </div>
</main>
<script>
(function() {
  const form = document.getElementById('bugReportForm');
  const status = document.getElementById('bugFormStatus');
  const btn = document.getElementById('bugSubmitBtn');
  if (!form) return;
  form.addEventListener('submit', async function(e) {
    e.preventDefault();
    btn.disabled = true;
    status.textContent = 'Sending…';
    status.style.color = '';
    try {
      const fd = new FormData(form);
      const res = await fetch('/api/bug-report', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: fd.get('name'),
          email: fd.get('email'),
          message: fd.get('message'),
          website: fd.get('website'),
          page: document.referrer || location.href,
        }),
      });
      const data = await res.json().catch(() => ({}));
      if (res.ok) {
        form.reset();
        status.textContent = '✅ Thanks! Your report has been received.';
        status.style.color = '#1baf7a';
      } else {
        status.textContent = data.error || 'Something went wrong — please email us instead.';
        status.style.color = '#e34948';
        btn.disabled = false;
      }
    } catch {
      status.textContent = 'Network error — please email us instead.';
      status.style.color = '#e34948';
      btn.disabled = false;
    }
  });
})();
</script>
<%- include('partials/footer') %>
