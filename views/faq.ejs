<%- include('partials/head') %>
<%- include('partials/nav') %>
<main id="main-content" class="content-page">
  <div class="container">
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <a href="/">Home</a><span class="sep">›</span><span>FAQ</span>
    </nav>
    <h1>Frequently Asked Questions</h1>
    <p class="page-subtitle">Everything you want to know about playing UNO online.</p>

    <div class="faq-list">
      <% faqs.forEach(function(faq, i) { %>
      <details class="faq-item" id="faq-<%= i %>">
        <summary class="faq-question"><%= faq.q %></summary>
        <div class="faq-answer"><p><%- faq.a %></p></div>
      </details>
      <% }); %>
    </div>

    <div class="cta-banner">
      <h3>Still Have Questions?</h3>
      <p>The best way to learn is to play! Start a game and figure it out as you go.</p>
      <a href="/play" class="btn btn-hero">Play UNO Free Now</a>
    </div>
  </div>
</main>
<%- include('partials/footer') %>
