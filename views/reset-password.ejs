<%- include('partials/head') %>
<%- include('partials/nav') %>
<main id="main-content" class="content-page" style="min-height:60vh;">
  <div class="container" style="max-width:440px;">
    <h1 style="text-align:center;">🔒 Reset Password</h1>
    <p class="page-subtitle" style="text-align:center;margin-bottom:32px;">
      Choose a new password for your account.
    </p>

    <form id="reset-form" style="display:flex;flex-direction:column;gap:16px;">
      <label for="password" style="font-size:0.85rem;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:1px;">New Password</label>
      <input type="password" id="password" required minlength="6" placeholder="At least 6 characters" autocomplete="new-password"
        style="padding:14px 16px;font-size:1rem;border-radius:10px;border:1px solid rgba(139,147,168,0.35);background:rgba(5,7,13,0.55);color:inherit;outline:none;" />
      <label for="password2" style="font-size:0.85rem;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:1px;">Confirm Password</label>
      <input type="password" id="password2" required minlength="6" placeholder="Same password again" autocomplete="new-password"
        style="padding:14px 16px;font-size:1rem;border-radius:10px;border:1px solid rgba(139,147,168,0.35);background:rgba(5,7,13,0.55);color:inherit;outline:none;" />
      <button type="submit" id="submit-btn" class="btn btn-hero" style="width:100%;">Set New Password</button>
      <p id="msg" style="display:none;padding:12px 16px;border-radius:10px;font-size:0.9rem;"></p>
    </form>

    <p style="text-align:center;margin-top:28px;">
      <a href="/play" style="color:var(--text-secondary);">← Back to the game</a>
    </p>
  </div>
</main>
<script>
  document.getElementById('reset-form').addEventListener('submit', async function (e) {
    e.preventDefault();
    var msg = document.getElementById('msg');
    var btn = document.getElementById('submit-btn');
    var p1 = document.getElementById('password').value;
    var p2 = document.getElementById('password2').value;

    function show(text, ok) {
      msg.style.display = 'block';
      msg.style.background = ok ? 'rgba(46,232,138,0.12)' : 'rgba(255,59,92,0.12)';
      msg.style.border = ok ? '1px solid rgba(46,232,138,0.4)' : '1px solid rgba(255,59,92,0.4)';
      msg.innerHTML = text;
    }

    if (p1 !== p2) return show('Passwords do not match.', false);

    var token = new URLSearchParams(location.search).get('token');
    if (!token) return show('This reset link is incomplete — use the link from your email.', false);

    btn.disabled = true; btn.textContent = 'Saving…';
    try {
      var res = await fetch('/api/auth/reset', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ token: token, password: p1 })
      });
      var data = await res.json();
      if (!res.ok) { show(data.error || 'Reset failed.', false); }
      else {
        // Signed in automatically — hand the session to the game
        if (data.token) localStorage.setItem('uno_token', data.token);
        show('✓ Password updated — you are signed in. <a href="/play">Back to the game →</a>', true);
        document.getElementById('reset-form').querySelectorAll('input,button').forEach(function (el) { el.disabled = true; });
      }
    } catch (err) {
      show('Something went wrong — please try again.', false);
    }
    if (!btn.disabled) { btn.textContent = 'Set New Password'; }
  });
</script>
<%- include('partials/footer') %>
