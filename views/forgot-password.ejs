<%- include('partials/head') %>
<%- include('partials/nav') %>
<main id="main-content" class="content-page" style="min-height:60vh;">
  <div class="container" style="max-width:440px;">
    <h1 style="text-align:center;">🔑 Forgot Password</h1>
    <p class="page-subtitle" style="text-align:center;margin-bottom:32px;">
      Enter your account email and we'll send you a link to reset your password.
    </p>

    <form id="forgot-form" style="display:flex;flex-direction:column;gap:16px;">
      <label for="email" style="font-size:0.85rem;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:1px;">Email</label>
      <input type="email" id="email" required placeholder="you@example.com" autocomplete="email"
        style="padding:14px 16px;font-size:1rem;border-radius:10px;border:1px solid rgba(139,147,168,0.35);background:rgba(5,7,13,0.55);color:inherit;outline:none;" />
      <button type="submit" id="submit-btn" class="btn btn-hero" style="width:100%;">Send Reset Link</button>
      <p id="msg" style="display:none;padding:12px 16px;border-radius:10px;font-size:0.9rem;"></p>
    </form>

    <p style="text-align:center;margin-top:28px;">
      <a href="/play" style="color:var(--text-secondary);">← Back to the game</a>
    </p>
  </div>
</main>
<script>
  document.getElementById('forgot-form').addEventListener('submit', async function (e) {
    e.preventDefault();
    var btn = document.getElementById('submit-btn');
    var msg = document.getElementById('msg');
    btn.disabled = true; btn.textContent = 'Sending…';
    try {
      var res = await fetch('/api/auth/forgot', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: document.getElementById('email').value.trim() })
      });
      var data = await res.json();
      msg.style.display = 'block';
      msg.style.background = 'rgba(46,232,138,0.12)';
      msg.style.border = '1px solid rgba(46,232,138,0.4)';
      msg.textContent = data.message || 'If an account exists for that email, a reset link is on its way.';
    } catch (err) {
      msg.style.display = 'block';
      msg.style.background = 'rgba(255,59,92,0.12)';
      msg.style.border = '1px solid rgba(255,59,92,0.4)';
      msg.textContent = 'Something went wrong — please try again.';
    }
    btn.disabled = false; btn.textContent = 'Send Reset Link';
  });
</script>
<%- include('partials/footer') %>
