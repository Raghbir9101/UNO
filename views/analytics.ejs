<%- include('partials/head') %>
<style>
/* Data Viz Palette */
:root {
  --surface-1: #fcfcfb;
  --page-plane: #f9f9f7;
  --text-primary: #0b0b0b;
  --text-secondary: #52514e;
  --text-muted: #898781;
  --gridline: #e1e0d9;
  --baseline: #c3c2b7;
  --border: rgba(11,11,11,0.10);
  --series-1: #2a78d6;
  --series-2: #1baf7a;
  --series-3: #eda100;
  --series-4: #008300;
  --series-5: #4a3aa7;
  --series-6: #e34948;
  --series-7: #e87ba4;
  --series-8: #eb6834;
}

@media (prefers-color-scheme: dark) {
  :root {
    --surface-1: #1a1a19;
    --page-plane: #0d0d0d;
    --text-primary: #ffffff;
    --text-secondary: #c3c2b7;
    --text-muted: #898781;
    --gridline: #2c2c2a;
    --baseline: #383835;
    --border: rgba(255,255,255,0.10);
    --series-1: #3987e5;
    --series-2: #199e70;
    --series-3: #c98500;
    --series-4: #008300;
    --series-5: #9085e9;
    --series-6: #e66767;
    --series-7: #d55181;
    --series-8: #d95926;
  }
}

.analytics-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 16px;
  margin-bottom: 32px;
}

.stat-tile {
  background: var(--surface-1);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 20px;
  transition: transform 0.2s, box-shadow 0.2s;
}

.stat-tile:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 16px rgba(0,0,0,0.1);
}

.stat-label {
  font-size: 0.75rem;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 8px;
}

.stat-value {
  font-size: 2.5rem;
  font-weight: 800;
  color: var(--text-primary);
  line-height: 1;
  margin-bottom: 4px;
}

.stat-meta {
  font-size: 0.85rem;
  color: var(--text-secondary);
}

.chart-card {
  background: var(--surface-1);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 24px;
  margin-bottom: 24px;
}

.chart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20px;
}

.chart-title {
  font-size: 1.25rem;
  font-weight: 700;
  color: var(--text-primary);
  margin: 0;
}

.filters-bar {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  margin-bottom: 24px;
  padding: 16px;
  background: var(--page-plane);
  border-radius: 8px;
}

.filter-group {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.filter-label {
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  color: var(--text-muted);
  font-weight: 600;
}

.filter-select, .filter-input {
  padding: 8px 12px;
  border: 1px solid var(--baseline);
  border-radius: 6px;
  background: var(--surface-1);
  color: var(--text-primary);
  font-size: 0.9rem;
  min-width: 160px;
}

.filter-select:focus, .filter-input:focus {
  outline: 2px solid var(--series-1);
  outline-offset: 2px;
}

.line-chart {
  position: relative;
  height: 280px;
  margin-bottom: 16px;
}

.chart-canvas {
  display: flex;
  align-items: flex-end;
  gap: 4px;
  height: 100%;
  position: relative;
}

.chart-bar {
  flex: 1;
  background: linear-gradient(180deg, var(--series-1), var(--series-6));
  border-radius: 4px 4px 0 0;
  min-width: 6px;
  cursor: pointer;
  transition: opacity 0.2s;
  position: relative;
}

.chart-bar:hover {
  opacity: 0.8;
}

.chart-bar::after {
  content: attr(data-value);
  position: absolute;
  bottom: 100%;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0,0,0,0.9);
  color: white;
  padding: 4px 8px;
  border-radius: 4px;
  font-size: 0.75rem;
  white-space: nowrap;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.2s;
  z-index: 10;
}

.chart-bar:hover::after {
  opacity: 1;
}

.chart-axis {
  display: flex;
  justify-content: space-between;
  font-size: 0.7rem;
  color: var(--text-muted);
  margin-top: 8px;
}

.donut-chart {
  display: flex;
  align-items: center;
  gap: 32px;
  flex-wrap: wrap;
}

.donut-svg {
  flex-shrink: 0;
}

.donut-legend {
  flex: 1;
  min-width: 200px;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 12px;
}

.legend-color {
  width: 32px;
  height: 20px;
  border-radius: 4px;
  flex-shrink: 0;
}

.legend-label {
  flex: 1;
  font-size: 0.9rem;
  color: var(--text-primary);
  text-transform: capitalize;
}

.legend-value {
  font-weight: 700;
  font-size: 0.95rem;
  color: var(--text-primary);
}

.data-table-wrapper {
  overflow-x: auto;
  border-radius: 8px;
  border: 1px solid var(--border);
  margin-bottom: 16px;
}

.data-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.875rem;
}

.data-table thead {
  background: var(--page-plane);
  position: sticky;
  top: 0;
  z-index: 5;
}

.data-table th {
  padding: 12px 16px;
  text-align: left;
  font-weight: 600;
  color: var(--text-muted);
  text-transform: uppercase;
  font-size: 0.75rem;
  letter-spacing: 0.5px;
  border-bottom: 2px solid var(--baseline);
  cursor: pointer;
  user-select: none;
}

.data-table th:hover {
  background: var(--surface-1);
}

.data-table th.sortable::after {
  content: ' ↕';
  opacity: 0.3;
}

.data-table th.sort-asc::after {
  content: ' ↑';
  opacity: 1;
}

.data-table th.sort-desc::after {
  content: ' ↓';
  opacity: 1;
}

.data-table td {
  padding: 12px 16px;
  border-bottom: 1px solid var(--gridline);
  color: var(--text-primary);
}

.data-table tbody tr:hover {
  background: var(--page-plane);
}

.data-table tbody tr.bot-row {
  opacity: 0.6;
  background: repeating-linear-gradient(
    45deg,
    transparent,
    transparent 10px,
    rgba(139,147,168,0.05) 10px,
    rgba(139,147,168,0.05) 20px
  );
}

.data-table tbody tr.bot-row td {
  font-style: italic;
}

.bot-badge {
  display: inline-block;
  padding: 2px 6px;
  background: var(--text-muted);
  color: var(--surface-1);
  border-radius: 3px;
  font-size: 0.65rem;
  font-weight: 700;
  text-transform: uppercase;
  margin-left: 6px;
  font-style: normal;
}

.data-table .metric-cell {
  font-family: 'Consolas', 'Monaco', monospace;
  font-variant-numeric: tabular-nums;
}

.data-table a {
  color: var(--series-1);
  text-decoration: none;
  transition: opacity 0.2s;
}

.data-table a:hover {
  opacity: 0.7;
  text-decoration: underline;
}

.pagination {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 8px;
  margin-top: 24px;
}

.pagination button {
  padding: 8px 14px;
  border: 1px solid var(--baseline);
  background: var(--surface-1);
  color: var(--text-primary);
  border-radius: 6px;
  cursor: pointer;
  font-size: 0.875rem;
  transition: all 0.2s;
}

.pagination button:hover:not(:disabled) {
  background: var(--series-1);
  color: white;
  border-color: var(--series-1);
}

.pagination button:disabled {
  opacity: 0.4;
  cursor: not-allowed;
}

.pagination .page-info {
  padding: 0 12px;
  font-size: 0.875rem;
  color: var(--text-secondary);
}

@media (max-width: 768px) {
  .analytics-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .stat-value {
    font-size: 2rem;
  }

  .donut-chart {
    flex-direction: column;
  }

  .filters-bar {
    flex-direction: column;
  }

  .filter-select, .filter-input {
    width: 100%;
  }
}
</style>

<main id="main-content" class="content-page">
  <div class="container" style="max-width:1400px;">
    <h1>📈 Site Analytics</h1>
    <p class="page-subtitle" style="margin-bottom:32px;">Human traffic only — bot/crawler hits are counted separately below.</p>

    <!-- Search Filter -->
    <div class="filters-bar">
      <div class="filter-group">
        <label class="filter-label">Search Visits</label>
        <input type="text" class="filter-input" id="pathSearch" placeholder="Search by path, location, IP, or device...">
      </div>
      <div class="filter-group">
        <label class="filter-label">Device Filter</label>
        <select class="filter-select" id="deviceFilter">
          <option value="all">All Devices</option>
          <option value="mobile">Mobile</option>
          <option value="desktop">Desktop</option>
          <option value="tablet">Tablet</option>
          <option value="bot">Bots Only</option>
        </select>
      </div>
      <div class="filter-group">
        <label class="filter-label">View Mode</label>
        <select class="filter-select" id="viewMode">
          <option value="human">Human Traffic Only</option>
          <option value="all">All Traffic (+ Bots)</option>
          <option value="bots">Bots Only</option>
        </select>
      </div>
    </div>

    <!-- Stat Tiles -->
    <div class="analytics-grid">
      <div class="stat-tile">
        <div class="stat-label">Today</div>
        <div class="stat-value"><%= data.totals.visitsToday.toLocaleString() %></div>
        <div class="stat-meta"><%= data.totals.uniqToday.toLocaleString() %> unique visitors</div>
      </div>

      <div class="stat-tile">
        <div class="stat-label">Last 7 Days</div>
        <div class="stat-value"><%= data.totals.visits7d.toLocaleString() %></div>
        <div class="stat-meta"><%= data.totals.uniq7d.toLocaleString() %> unique visitors</div>
      </div>

      <div class="stat-tile">
        <div class="stat-label">Last 30 Days</div>
        <div class="stat-value"><%= data.totals.visits30d.toLocaleString() %></div>
        <div class="stat-meta"><%= data.totals.uniq30d.toLocaleString() %> unique visitors</div>
      </div>

      <div class="stat-tile">
        <div class="stat-label">All Time</div>
        <div class="stat-value"><%= data.totals.visitsAll.toLocaleString() %></div>
        <div class="stat-meta">page views</div>
      </div>
    </div>

    <!-- Games: live + totals -->
    <%
    const liveRooms = data.liveRooms || [];
    const playingRooms = liveRooms.filter(r => r.status === 'playing');
    const humansOnline = liveRooms.reduce((n, r) => n + r.players.filter(p => !p.isBot && p.connected).length, 0);
    const fmtDuration = (ms) => {
      const s = Math.round(ms / 1000);
      return Math.floor(s / 60) + 'm ' + (s % 60) + 's';
    };
    const fmtRules = (rules) => (rules && rules.length) ? rules.join(', ') : '—';
    %>
    <div class="analytics-grid">
      <div class="stat-tile">
        <div class="stat-label">🟢 Live Rooms</div>
        <div class="stat-value"><%= liveRooms.length %></div>
        <div class="stat-meta"><%= playingRooms.length %> mid-game, <%= liveRooms.length - playingRooms.length %> in lobby</div>
      </div>
      <div class="stat-tile">
        <div class="stat-label">Players Online</div>
        <div class="stat-value"><%= humansOnline %></div>
        <div class="stat-meta">connected humans (bots excluded)</div>
      </div>
      <div class="stat-tile">
        <div class="stat-label">Games Today</div>
        <div class="stat-value"><%= data.gamesToday.toLocaleString() %></div>
        <div class="stat-meta">finished games since midnight</div>
      </div>
      <div class="stat-tile">
        <div class="stat-label">Games All Time</div>
        <div class="stat-value"><%= data.gamesAll.toLocaleString() %></div>
        <div class="stat-meta">finished games (180-day retention)</div>
      </div>
    </div>

    <!-- Live Rooms -->
    <div class="chart-card">
      <div class="chart-header">
        <h2 class="chart-title">🎮 Live Rooms (right now)</h2>
      </div>
      <div class="data-table-wrapper">
        <table class="data-table">
          <thead>
            <tr>
              <th>Room</th>
              <th>Status</th>
              <th>Players</th>
              <th>Spectators</th>
              <th>Rules</th>
              <th>Visibility</th>
              <th>Created</th>
            </tr>
          </thead>
          <tbody>
            <% if (liveRooms.length) { %>
              <% liveRooms.forEach(function(r) { %>
                <tr>
                  <td class="metric-cell"><%= r.code %></td>
                  <td><%= r.status === 'playing' ? '▶️ Playing' : '🕐 Lobby' %></td>
                  <td>
                    <% r.players.forEach(function(p, i) { %><%= i ? ', ' : '' %><span style="<%= p.connected ? '' : 'opacity:0.45; text-decoration:line-through;' %>"><%= p.nickname %></span><% if (p.isBot) { %><span class="bot-badge">BOT</span><% } %><% }); %>
                  </td>
                  <td class="metric-cell"><%= r.spectators || '—' %></td>
                  <td><%= fmtRules(r.rules) %></td>
                  <td><%= r.isPrivate ? '🔒 Private' : '🌐 Public' %></td>
                  <td class="metric-cell" style="white-space: nowrap;"><%= new Date(r.createdAt).toLocaleString('en-IN', { timeZone: 'Asia/Kolkata' }) %></td>
                </tr>
              <% }); %>
            <% } else { %>
              <tr><td colspan="7" style="text-align: center; padding: 40px; color: var(--text-muted);">No rooms open right now.</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Game History -->
    <div class="chart-card">
      <div class="chart-header">
        <h2 class="chart-title">🏁 Game History (latest 100)</h2>
      </div>
      <div class="data-table-wrapper">
        <table class="data-table">
          <thead>
            <tr>
              <th>Finished</th>
              <th>Room</th>
              <th>Winner</th>
              <th>Players</th>
              <th>Duration</th>
              <th>Rules</th>
            </tr>
          </thead>
          <tbody>
            <% const gameHistory = data.gameHistory || []; %>
            <% if (gameHistory.length) { %>
              <% gameHistory.forEach(function(g) { %>
                <tr>
                  <td class="metric-cell" style="white-space: nowrap;"><%= new Date(g.ts).toLocaleString('en-IN', { timeZone: 'Asia/Kolkata' }) %></td>
                  <td class="metric-cell"><%= g.roomCode %> <%= g.isPrivate ? '🔒' : '' %></td>
                  <td>
                    <strong><%= g.winnerName %></strong>
                    <% if (g.winnerIsBot) { %><span class="bot-badge">BOT</span><% } %>
                  </td>
                  <td style="max-width: 340px;">
                    <span class="metric-cell"><%= g.humanCount %>👤<%= g.botCount ? ' + ' + g.botCount + '🤖' : '' %></span> —
                    <% (g.players || []).forEach(function(p, i) { %><%= i ? ', ' : '' %><%= p.nickname %><% }); %>
                  </td>
                  <td class="metric-cell"><%= fmtDuration(g.durationMs || 0) %></td>
                  <td><%= fmtRules(g.rules) %></td>
                </tr>
              <% }); %>
            <% } else { %>
              <tr><td colspan="6" style="text-align: center; padding: 40px; color: var(--text-muted);">No finished games recorded yet. Every game that ends from now on will appear here.</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Daily Visits Line Chart -->
    <div class="chart-card">
      <div class="chart-header">
        <h2 class="chart-title">Daily Visits (14 days)</h2>
      </div>
      <div class="line-chart">
        <div class="chart-canvas">
          <% const maxDaily = Math.max(1, ...data.daily.map(d => d.count)); %>
          <% data.daily.forEach(function(d) {
            const height = Math.max(4, Math.round(d.count / maxDaily * 100));
            const date = new Date(d._id).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
          %>
            <div class="chart-bar"
                 style="height: <%= height %>%;"
                 data-value="<%= d.count %> visits"
                 data-date="<%= date %>"
                 title="<%= date %>: <%= d.count %>"></div>
          <% }); %>
        </div>
      </div>
      <div class="chart-axis">
        <span><%= data.daily[0] ? new Date(data.daily[0]._id).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) : '' %></span>
        <span><%= data.daily.length ? new Date(data.daily[data.daily.length-1]._id).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) : '' %></span>
      </div>
    </div>

    <!-- Device Breakdown Donut Chart -->
    <div class="chart-card">
      <div class="chart-header">
        <h2 class="chart-title">Device Breakdown (30 days)</h2>
      </div>
      <div class="donut-chart">
        <svg class="donut-svg" width="200" height="200" viewBox="0 0 200 200">
          <%
          const total = data.devices.reduce((sum, d) => sum + d.count, 0);
          let currentAngle = -90;
          const colors = ['--series-1', '--series-2', '--series-3', '--series-4', '--series-5'];
          %>
          <% data.devices.forEach((device, i) => {
            const percentage = device.count / total;
            const angle = percentage * 360;
            const endAngle = currentAngle + angle;
            const largeArc = angle > 180 ? 1 : 0;

            const startX = 100 + 70 * Math.cos(currentAngle * Math.PI / 180);
            const startY = 100 + 70 * Math.sin(currentAngle * Math.PI / 180);
            const endX = 100 + 70 * Math.cos(endAngle * Math.PI / 180);
            const endY = 100 + 70 * Math.sin(endAngle * Math.PI / 180);

            currentAngle = endAngle;
          %>
            <path d="M 100,100 L <%= startX %>,<%= startY %> A 70,70 0 <%= largeArc %>,1 <%= endX %>,<%= endY %> Z"
                  fill="var(<%= colors[i % colors.length] %>)"
                  opacity="0.9">
              <title><%= device._id %>: <%= device.count %> (<%= (percentage * 100).toFixed(1) %>%)</title>
            </path>
          <% }); %>
          <circle cx="100" cy="100" r="45" fill="var(--surface-1)" />
        </svg>

        <div class="donut-legend">
          <% data.devices.forEach((device, i) => {
            const percentage = (device.count / total * 100).toFixed(1);
          %>
            <div class="legend-item">
              <div class="legend-color" style="background: var(<%= colors[i % colors.length] %>);"></div>
              <span class="legend-label"><%= device._id %></span>
              <span class="legend-value"><%= device.count %> (<%= percentage %>%)</span>
            </div>
          <% }); %>
          <div class="legend-item">
            <div class="legend-color" style="background: var(--text-muted); opacity: 0.3;"></div>
            <span class="legend-label">Bot hits</span>
            <span class="legend-value"><%= data.totals.botHits30d %></span>
          </div>
        </div>
      </div>
    </div>

    <!-- Top Pages Table -->
    <div class="chart-card">
      <div class="chart-header">
        <h2 class="chart-title">Top Pages (30 days)</h2>
      </div>
      <div class="data-table-wrapper">
        <table class="data-table" id="pagesTable">
          <thead>
            <tr>
              <th class="sortable" data-sort="path">Page</th>
              <th class="sortable" data-sort="count">Visits</th>
              <th class="sortable" data-sort="percentage">Percentage</th>
            </tr>
          </thead>
          <tbody>
            <% const totalPageViews = data.topPages.reduce((sum, p) => sum + p.count, 0); %>
            <% data.topPages.forEach(function(p) {
              const percentage = (p.count / totalPageViews * 100).toFixed(1);
              const fullUrl = (process.env.BASE_URL || 'https://playunofree.com') + p._id;
            %>
              <tr>
                <td><a href="<%= fullUrl %>" target="_blank" style="color: var(--series-1); text-decoration: none;"><%= fullUrl %></a></td>
                <td class="metric-cell"><%= p.count.toLocaleString() %></td>
                <td class="metric-cell"><%= percentage %>%</td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Countries & Cities Grid -->
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(400px, 1fr)); gap: 24px; margin-bottom: 24px;">
      <div class="chart-card">
        <div class="chart-header">
          <h2 class="chart-title">Top Countries (30 days)</h2>
        </div>
        <div class="data-table-wrapper">
          <table class="data-table">
            <thead>
              <tr>
                <th>Country</th>
                <th style="text-align: right;">Visits</th>
              </tr>
            </thead>
            <tbody>
              <% data.topCountries.slice(0, 10).forEach(function(c) { %>
                <tr>
                  <td><%= c._id %></td>
                  <td class="metric-cell" style="text-align: right;"><%= c.count.toLocaleString() %></td>
                </tr>
              <% }); %>
              <% if (!data.topCountries.length) { %>
                <tr><td colspan="2" style="text-align: center; color: var(--text-muted);">No geo data yet</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

      <div class="chart-card">
        <div class="chart-header">
          <h2 class="chart-title">Top Cities (30 days)</h2>
        </div>
        <div class="data-table-wrapper">
          <table class="data-table">
            <thead>
              <tr>
                <th>City</th>
                <th style="text-align: right;">Visits</th>
              </tr>
            </thead>
            <tbody>
              <% data.topCities.slice(0, 10).forEach(function(c) { %>
                <tr>
                  <td><%= c._id.city %>, <%= c._id.country %></td>
                  <td class="metric-cell" style="text-align: right;"><%= c.count.toLocaleString() %></td>
                </tr>
              <% }); %>
              <% if (!data.topCities.length) { %>
                <tr><td colspan="2" style="text-align: center; color: var(--text-muted);">—</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Referrers Table -->
    <div class="chart-card">
      <div class="chart-header">
        <h2 class="chart-title">Top Referrers (30 days)</h2>
      </div>
      <div class="data-table-wrapper">
        <table class="data-table">
          <thead>
            <tr>
              <th>Referrer</th>
              <th style="text-align: right;">Visits</th>
            </tr>
          </thead>
          <tbody>
            <% data.topReferrers.forEach(function(r) { %>
              <tr>
                <td><%= r._id %></td>
                <td class="metric-cell" style="text-align: right;"><%= r.count.toLocaleString() %></td>
              </tr>
            <% }); %>
            <% if (!data.topReferrers.length) { %>
              <tr><td colspan="2" style="text-align: center; color: var(--text-muted);">No external referrers yet</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Recent Visits Table with Pagination -->
    <div class="chart-card">
      <div class="chart-header">
        <h2 class="chart-title">All Visits</h2>
      </div>
      <div class="data-table-wrapper">
        <table class="data-table" id="recentVisitsTable">
          <thead>
            <tr>
              <th class="sortable" data-sort="time">Time</th>
              <th class="sortable" data-sort="path">Path</th>
              <th class="sortable" data-sort="location">Location</th>
              <th class="sortable" data-sort="ip">IP</th>
              <th class="sortable" data-sort="device">Device</th>
              <th>Referrer</th>
            </tr>
          </thead>
          <tbody id="recentVisitsBody">
            <%
            // Combine human and bot visits, mark bots
            const humanVisits = (data.recent || []).map(v => ({ ...v, isBot: false }));
            const botVisitsArray = Array.isArray(data.botVisits) ? data.botVisits.map(v => ({ ...v, isBot: true })) : [];
            const allVisits = [...humanVisits, ...botVisitsArray].sort((a, b) => new Date(b.ts) - new Date(a.ts));

            if (allVisits && allVisits.length > 0) { %>
              <% allVisits.forEach(function(v) {
                const fullUrl = (process.env.BASE_URL || 'https://playunofree.com') + v.path;
                const rowClass = v.isBot ? 'bot-row' : '';
                const dataBot = v.isBot ? 'true' : 'false';
              %>
                <tr class="<%= rowClass %>" data-is-bot="<%= dataBot %>">
                  <td class="metric-cell"><%= new Date(v.ts).toLocaleString('en-IN', { timeZone: 'Asia/Kolkata' }) %></td>
                  <td><a href="<%= fullUrl %>" target="_blank"><%= fullUrl %></a></td>
                  <td><%= [v.city, v.country].filter(Boolean).join(', ') || '—' %></td>
                  <td class="metric-cell" style="font-family: monospace;"><%= v.ip || '—' %></td>
                  <td style="text-transform: capitalize;">
                    <%= v.device %>
                    <% if (v.isBot) { %><span class="bot-badge">BOT</span><% } %>
                  </td>
                  <td style="max-width: 220px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"><%= v.referer || '—' %></td>
                </tr>
              <% }); %>
            <% } else { %>
              <tr>
                <td colspan="6" style="text-align: center; padding: 40px; color: var(--text-muted);">
                  No visits recorded yet. Visits will appear here once users access the site.
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>

      <div class="pagination" id="visitsPagination">
        <button id="prevPage" disabled>← Previous</button>
        <span class="page-info">
          Page <span id="currentPage">1</span> of <span id="totalPages">1</span>
          <span id="filterInfo" style="margin-left: 12px; color: var(--text-muted);"></span>
        </span>
        <button id="nextPage" disabled>Next →</button>
      </div>
    </div>

    <!-- Bug Reports -->
    <div class="chart-card">
      <div class="chart-header">
        <h2 class="chart-title">🐞 Bug Reports (latest 100)</h2>
      </div>
      <div class="data-table-wrapper">
        <table class="data-table">
          <thead>
            <tr>
              <th>Time</th>
              <th>From</th>
              <th>Report</th>
              <th>Page</th>
              <th>Device</th>
            </tr>
          </thead>
          <tbody>
            <% const bugReports = data.bugReports || []; %>
            <% if (bugReports.length) { %>
              <% bugReports.forEach(function(b) { %>
                <tr>
                  <td class="metric-cell" style="white-space: nowrap;"><%= new Date(b.ts).toLocaleString('en-IN', { timeZone: 'Asia/Kolkata' }) %></td>
                  <td>
                    <%= b.name || 'Anonymous' %>
                    <% if (b.email) { %><br><a href="mailto:<%= b.email %>"><%= b.email %></a><% } %>
                  </td>
                  <td style="max-width: 420px; white-space: pre-wrap; word-break: break-word;"><%= b.message %></td>
                  <td style="max-width: 180px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"><%= b.page || '—' %></td>
                  <td style="max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="<%= b.userAgent %>"><%= b.userAgent || '—' %></td>
                </tr>
              <% }); %>
            <% } else { %>
              <tr><td colspan="5" style="text-align: center; padding: 40px; color: var(--text-muted);">No bug reports yet. Reports from the /contact form will appear here.</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</main>

<script>
// Table sorting
document.querySelectorAll('.data-table th.sortable').forEach(header => {
  header.addEventListener('click', function() {
    const table = this.closest('table');
    const tbody = table.querySelector('tbody');
    const rows = Array.from(tbody.querySelectorAll('tr'));
    const column = this.dataset.sort;
    const currentSort = this.classList.contains('sort-asc') ? 'asc' :
                        this.classList.contains('sort-desc') ? 'desc' : 'none';

    table.querySelectorAll('th').forEach(h => {
      h.classList.remove('sort-asc', 'sort-desc');
    });

    const newSort = currentSort === 'none' ? 'desc' :
                    currentSort === 'desc' ? 'asc' : 'desc';
    this.classList.add(newSort === 'asc' ? 'sort-asc' : 'sort-desc');

    const columnIndex = Array.from(this.parentElement.children).indexOf(this);
    rows.sort((a, b) => {
      let aVal = a.children[columnIndex].textContent.trim();
      let bVal = b.children[columnIndex].textContent.trim();

      const aNum = parseFloat(aVal.replace(/[,%]/g, ''));
      const bNum = parseFloat(bVal.replace(/[,%]/g, ''));

      if (!isNaN(aNum) && !isNaN(bNum)) {
        return newSort === 'asc' ? aNum - bNum : bNum - aNum;
      }

      return newSort === 'asc' ? aVal.localeCompare(bVal) : bVal.localeCompare(aVal);
    });

    rows.forEach(row => tbody.appendChild(row));
  });
});

// Pagination and Filtering for recent visits
const ROWS_PER_PAGE = 25;
let currentPage = 1;
const allRows = Array.from(document.querySelectorAll('#recentVisitsBody tr'));

function applyFiltersAndPagination() {
  // Get rows that match current filters
  const visibleRows = allRows.filter(row => {
    const filterHidden = row.getAttribute('data-filter-hidden') === 'true';
    return !filterHidden;
  });

  // Calculate pagination
  const totalPages = Math.max(1, Math.ceil(visibleRows.length / ROWS_PER_PAGE));
  const start = (currentPage - 1) * ROWS_PER_PAGE;
  const end = start + ROWS_PER_PAGE;

  // Update UI
  document.getElementById('currentPage').textContent = currentPage;
  document.getElementById('totalPages').textContent = totalPages;
  document.getElementById('prevPage').disabled = currentPage === 1;
  document.getElementById('nextPage').disabled = currentPage >= totalPages;

  // Show filter info
  const filterInfo = document.getElementById('filterInfo');
  if (visibleRows.length < allRows.length) {
    filterInfo.textContent = `(showing ${visibleRows.length} of ${allRows.length} visits)`;
  } else {
    filterInfo.textContent = `(${allRows.length} total visits)`;
  }

  // Apply visibility to all rows
  allRows.forEach((row, i) => {
    const filterHidden = row.getAttribute('data-filter-hidden') === 'true';
    const rowIndex = visibleRows.indexOf(row);
    const inCurrentPage = rowIndex >= start && rowIndex < end;

    row.style.display = (!filterHidden && inCurrentPage) ? '' : 'none';
  });

  // Reset to page 1 if current page is beyond total
  if (currentPage > totalPages && totalPages > 0) {
    currentPage = 1;
    applyFiltersAndPagination();
  }
}

function changePage(newPage) {
  currentPage = newPage;
  applyFiltersAndPagination();
}

document.getElementById('prevPage').addEventListener('click', () => {
  if (currentPage > 1) changePage(currentPage - 1);
});

document.getElementById('nextPage').addEventListener('click', () => {
  const visibleRows = allRows.filter(row => row.getAttribute('data-filter-hidden') !== 'true');
  const totalPages = Math.max(1, Math.ceil(visibleRows.length / ROWS_PER_PAGE));
  if (currentPage < totalPages) changePage(currentPage + 1);
});

// Apply all filters
function applyAllFilters() {
  const search = document.getElementById('pathSearch').value.toLowerCase().trim();
  const selectedDevice = document.getElementById('deviceFilter').value.toLowerCase();
  const viewMode = document.getElementById('viewMode').value;

  allRows.forEach(row => {
    const isBot = row.getAttribute('data-is-bot') === 'true';

    // View mode filter
    let viewModeMatches = true;
    if (viewMode === 'human' && isBot) {
      viewModeMatches = false;
    } else if (viewMode === 'bots' && !isBot) {
      viewModeMatches = false;
    }

    // Search in: path (column 1), location (column 2), IP (column 3), device (column 4)
    const path = row.children[1]?.textContent.toLowerCase() || '';
    const location = row.children[2]?.textContent.toLowerCase() || '';
    const ip = row.children[3]?.textContent.toLowerCase() || '';
    const device = row.children[4]?.textContent.toLowerCase().replace(/\s*bot\s*/g, '') || '';

    // Check search match
    const searchMatches = !search ||
                         path.includes(search) ||
                         location.includes(search) ||
                         ip.includes(search) ||
                         device.includes(search);

    // Check device match (handle bot device separately)
    let deviceMatches = true;
    if (selectedDevice === 'bot') {
      deviceMatches = isBot;
    } else if (selectedDevice !== 'all') {
      deviceMatches = device === selectedDevice;
    }

    // Mark row as hidden if any filter doesn't match
    row.setAttribute('data-filter-hidden', (!searchMatches || !deviceMatches || !viewModeMatches) ? 'true' : 'false');
  });

  currentPage = 1; // Reset to first page when filtering
  applyFiltersAndPagination();
}

// Search filter
document.getElementById('pathSearch').addEventListener('input', applyAllFilters);

// Device filter
document.getElementById('deviceFilter').addEventListener('change', applyAllFilters);

// View mode filter
document.getElementById('viewMode').addEventListener('change', applyAllFilters);

// Initial render
allRows.forEach(row => row.setAttribute('data-filter-hidden', 'false'));
applyFiltersAndPagination();

console.log('📊 Enhanced Analytics Dashboard loaded - ' + allRows.length + ' total visits');
</script>

<%- include('partials/footer') %>
